# ---------------------------------------------------------------------------
# Home Hub environment variables
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# --- Supabase (Postgres + Auth + Storage) ---------------------------------
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Project Settings -> API -> service_role (server-only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Two-user allowlist (OPTIONAL) -----------------------------------------
# The real gate is user provisioning in Supabase (sign-in uses
# shouldCreateUser:false, so no one can self-register). This var is an OPTIONAL
# extra layer. Leave it unset to simply trust Supabase's user list, or set it
# to restrict sign-in to specific emails. Comma-separated, lowercase.
# ALLOWED_EMAILS=you@example.com,partner@example.com

# --- App URL (used for auth redirects / OAuth callbacks) -------------------
# In development: http://localhost:3000
# In production: your Vercel URL, e.g. https://home-hub.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google Calendar OAuth (two-way calendar sync) ------------------------
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client
# Authorized redirect URI must be: <NEXT_PUBLIC_SITE_URL>/api/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
